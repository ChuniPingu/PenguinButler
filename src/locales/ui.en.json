      "label": "Preview start (s)"
    },
    "previewStop": {
      "label": "Preview stop (s)"
    },
    "manualOffset": {
      "label": "Manual offset (s)",
      "description": "The offset set in Margrete."
    },
    "realOffset": {
      "label": "Real offset (s)",
      "description": "The final audio offset. Positive values shift audio later; negative values shift it earlier."
    },
    "initialBpm": {
      "label": "Initial BPM"
    },
