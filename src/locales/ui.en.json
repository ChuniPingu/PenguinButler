      "label": "Initial time signature",
      "placeholder": "4/4"
    },
    "blankMeasure": {
      "label": "Leading blank measure",
      "description": "When enabled, inserts a blank measure before the chart and audio."
    },
    "stageId": {
      "label": "Stage ID",
      "description": "The unique number used to identify this background in the game."
    },
    "notesFieldLine": {
      "label": "Field line color",
      "placeholder": "Search field lines…",
      "empty": "No field lines found."
    },
    "hcaKey": {
      "label": "HCA encryption key",
      "description": "The encryption key for output HCA audio files. Usually leave the default unless your target game build requires a different key.",
      "reset": "Reset to default"
    },
    "jacketFile": {
      "label": "Jacket file"
    },
    "jacketId": {
      "label": "Jacket ID",
      "description": "The filename used to identify this jacket in the game."
    },
    "backgroundFile": {
      "label": "Background file"
    },
    "mgxcId": {
      "description": "The Song ID used in Margrete."
    },
    "barOffset": {
      "label": "Measure offset (s)",
      "description": "Calculated from initial BPM and time signature."
    },
    "mainDifficulty": {
      "description": "Which difficulty's chart is used to read shared song metadata (title, genre, jacket, audio, and so on). If no chart is marked as the baseline, the highest difficulty is used."
    },
    "optionName": {
      "description": "A four-letter name for the output Option folder (for example, MINE)."
    },
    "batchSize": {
      "description": "How many songs can be converted at the same time. Enter -1 for no limit."
    },
    "ignoreCache": {
      "description": "When enabled, jacket, background, and audio are always reconverted, even if the source and output files have not changed."
    }
